# ---- Backend environment (copy to .env and fill in real values) ----

# Server
PORT=5000

# MongoDB Atlas connection string
# Atlas -> Database -> Connect -> Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth (Google Cloud Console -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3 (bucket "bluverse-lms" / region "ap-southeast-2" are hardcoded in source)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
